<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SkyscapeMidiDisplayer.ViewModels"
        xmlns:controls="using:SkyscapeMidiDisplayer.Controls"
        x:Class="SkyscapeMidiDisplayer.MidiInputMonitorWindow"
        x:DataType="vm:MidiInputMonitorViewModel"
        Title="MIDI 输入监视器"
        Width="800" Height="500"
        WindowStartupLocation="CenterOwner"
        MinWidth="600" MinHeight="400">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </Window.Styles>

    <Grid Margin="15" RowDefinitions="Auto,*,Auto,Auto">
        <!-- 设备选择区域 -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="10" CornerRadius="4">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="MIDI设备:" VerticalAlignment="Center" Foreground="White"/>
                <ComboBox ItemsSource="{Binding AvailableDevices}"
                          SelectedItem="{Binding SelectedDevice}"
                          Width="200" VerticalAlignment="Center"
                          IsEnabled="{Binding !IsConnected}"/>
                <Button Content="刷新" Command="{Binding RefreshDevicesCommand}"
                        Background="#606060" Foreground="White"
                        IsEnabled="{Binding !IsConnected}"/>
                <Button Content="连接" Command="{Binding ConnectCommand}"
                        Background="#0078D4" Foreground="White"
                        IsVisible="{Binding !IsConnected}"
                        IsEnabled="{Binding SelectedDevice, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <Button Content="断开" Command="{Binding DisconnectCommand}"
                        Background="#f44336" Foreground="White"
                        IsVisible="{Binding IsConnected}"/>
                <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center" 
                           Foreground="#808080" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 钢琴键盘显示区域 -->
        <Border Grid.Row="1" Background="#1E1E1E" Margin="0,10" CornerRadius="4">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0" Text="键盘状态" FontSize="14" FontWeight="Bold"
                           Foreground="White" Margin="10"/>
                <controls:MidiKeyboardControl Grid.Row="1"
                                              ActiveNotes="{Binding ActiveNotes}"
                                              Margin="10,0,10,10"/>
            </Grid>
        </Border>

        <!-- 踏板状态区域 -->
        <Border Grid.Row="2" Background="#2D2D30" Padding="10" CornerRadius="4" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="踏板状态" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                <Grid ColumnDefinitions="*,*,*">
                    <!-- 延音踏板 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                        <Border Width="30" Height="30" CornerRadius="4" Background="#4CAF50"
                                IsVisible="{Binding SustainPedalPressed}">
                            <TextBlock Text="S" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="30" Height="30" CornerRadius="4" Background="#404040"
                                IsVisible="{Binding !SustainPedalPressed}">
                            <TextBlock Text="S" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="延音踏板" VerticalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                    
                    <!-- 保持踏板 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                        <Border Width="30" Height="30" CornerRadius="4" Background="#2196F3"
                                IsVisible="{Binding SostenutoPedalPressed}">
                            <TextBlock Text="O" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="30" Height="30" CornerRadius="4" Background="#404040"
                                IsVisible="{Binding !SostenutoPedalPressed}">
                            <TextBlock Text="O" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="保持踏板" VerticalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                    
                    <!-- 柔音踏板 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                        <Border Width="30" Height="30" CornerRadius="4" Background="#FF9800"
                                IsVisible="{Binding SoftPedalPressed}">
                            <TextBlock Text="F" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="30" Height="30" CornerRadius="4" Background="#404040"
                                IsVisible="{Binding !SoftPedalPressed}">
                            <TextBlock Text="F" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="柔音踏板" VerticalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 状态信息 -->
        <Border Grid.Row="3" Background="#252526" Padding="10" CornerRadius="4">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <TextBlock Text="{Binding LastNoteInfo}" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    <TextBlock Text="|" Foreground="#666666" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LastCCInfo}" Foreground="#90CAF9" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="关闭" Command="{Binding CloseCommand}"
                        Background="#606060" Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</Window>