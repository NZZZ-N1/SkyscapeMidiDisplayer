<Window xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="using:SkyscapeMidiDisplayer.ViewModels" x:Class="SkyscapeMidiDisplayer.SettingsWindow" x:DataType="vm:SettingsViewModel" Title="设置" Width="500" Height="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <TabControl Grid.Row="0">
            <TabItem Header="通用">
                <StackPanel Spacing="15" VerticalAlignment="Center">
                    <CheckBox Content="显示水印" IsChecked="{Binding ShowWatermark}" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="音色:" Width="60" />
                        <ComboBox ItemsSource="{Binding AvailableSoundFonts}" SelectedItem="{Binding CurrentSoundFont}" Width="150" />
                    </StackPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="鸣谢">
                <ScrollViewer Margin="10">
                    <StackPanel Spacing="10">
                        <TextBlock FontSize="14" FontWeight="Bold">制作者:
                            Enzera(Bilibili-奈盏TrAnslucEnt)</TextBlock>
                        <TextBlock FontSize="14" FontWeight="Bold"></TextBlock>
                        
                        <TextBlock FontSize="14" FontWeight="Bold">使用的开源库：</TextBlock>
                        <TextBlock>
                            <Run FontWeight="Bold">Avalonia</Run> - 跨平台UI框架
                        </TextBlock>
                        <TextBlock>
                            <Run FontWeight="Bold">NAudio</Run> - .NET音频库
                        </TextBlock>
                        <TextBlock>
                            <Run FontWeight="Bold">Melanchall.DryWetMidi</Run> - MIDI处理库
                        </TextBlock>
                        <TextBlock>
                            <Run FontWeight="Bold">CommunityToolkit.Mvvm</Run> - MVVM工具包
                        </TextBlock>
                        <TextBlock>
                            <Run FontWeight="Bold">SkiaSharp</Run> - 跨平台2D图形库
                        </TextBlock>
                        <TextBlock>
                            <Run FontWeight="Bold">HarfBuzzSharp</Run> - 文本布局库
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0 20 0 0">
            <Button Content="确定" Command="{Binding SaveCommand}" Width="80" />
            <Button Content="取消" Command="{Binding CancelCommand}" Width="80" />
        </StackPanel>
    </Grid>
</Window>